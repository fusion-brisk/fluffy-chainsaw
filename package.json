{
  "name": "contentify",
  "version": "3.1.1",
  "private": true,
  "description": "Contentify monorepo — Figma plugin + Chrome extension + Yandex Cloud Relay",
  "license": "UNLICENSED",
  "author": "Contentify Team",
  "workspaces": [
    "packages/plugin",
    "packages/extension",
    "packages/jsx-emitter",
    "packages/cloud-relay"
  ],
  "scripts": {
    "build": "npm run build -w packages/plugin",
    "test": "npm run test -w packages/plugin",
    "typecheck": "npm run typecheck -w packages/plugin",
    "lint": "npm run lint -w packages/plugin",
    "lint:fix": "npm run lint:fix -w packages/plugin",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "npm run build:watch -w packages/plugin",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "coverage": "npx tsx tools/coverage-report.ts",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.5.3"
  }
}
