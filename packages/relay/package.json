{
  "name": "contentify-relay",
  "version": "1.1.0",
  "description": "Relay server for Chrome Extension <-> Figma Plugin communication with WebSocket support",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "build:pkg": "tsc && pkg . --targets node18-macos-x64,node18-macos-arm64 --out-path pkg-dist",
    "build:pkg:arm64": "tsc && pkg . --targets node18-macos-arm64 --out-path pkg-dist",
    "build:pkg:x64": "tsc && pkg . --targets node18-macos-x64 --out-path pkg-dist"
  },
  "pkg": {
    "assets": [],
    "outputPath": "pkg-dist",
    "scripts": []
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "pkg": "^5.8.1",
    "typescript": "^5.3.3"
  }
}
